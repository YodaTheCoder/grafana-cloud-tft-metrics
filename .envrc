# Grafana Cloud OTLP auth (set your credentials)
export OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic YOUR_BASE64_ENCODED_CREDENTIALS"

# Workspace-specific resource attributes for filtering in Grafana
export OTEL_SERVICE_NAME="copilot-chat"
export OTEL_RESOURCE_ATTRIBUTES="project.name=grafana-tft-metrics,project.team=platformio"
